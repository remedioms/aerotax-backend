# Build-Hygiene — was nicht ins Container-Image gehört
.git/
.gitignore
.github/
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Test/Dev-Only
tests/
qa_data/
loadtest/
docs/
*.test
.envrc
.env
.env.*
# HINWEIS: rate_limits/ ist ein Python-Package (app.py: `from rate_limits import …`)
# und MUSS ins Image — NICHT hier eintragen.

# Lokale Job-/Session-State (nicht persistent über Container hinweg —
# Supabase ist primary persistence; lokale Files nur Fallback)
jobs/
sessions/
pdfs/
_job_chunks_state/
jobs_state/
_user_history_state/
debug_snapshots/

# Editor-Artefakte
.vscode/
.idea/
.DS_Store
*.swp

# Andere Cloud-Configs (verwirrend für Cloud Run)
fly.toml
Procfile

# Markdown-Docs (nicht relevant fürs Image)
*.md
!CLAUDE.md
